# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly set line endings for all text files
*.ts text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

